{
  "name": "cf-openfile",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-based shared file server with room-key isolation",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:frontend": "cd frontend && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "cd frontend && npm run test:e2e",
    "db:migrate:local": "wrangler d1 migrations apply cf-openfile-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cf-openfile-db --remote",
    "lint": "tsc --noEmit && cd frontend && tsc --noEmit",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.5.0",
    "jose": "^5.6.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^5.20260714.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^4.0.0"
  }
}
